SELECT 
	a.idAlumno, 
	a.NIF, 
	a.nombre as "nombre alumno", 
	a.apellido1, 
	a.apellido2, 
	asig.curso, 
	asig.nombre as "nombre materia"
from asignatura asig
LEFT JOIN curso c on idCurso = asig.curso
LEFT JOIN matricula mat on mat.idAsignatura = asig.idAsignatura
left join alumno a on a.idAlumno = mat.idAlumno
order by a.NIF desc
